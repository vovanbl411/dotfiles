// ============================================
// Layout & Appearance Configuration
// ============================================

layout {
    // ==========================================
    // 1. Spacing & Gaps
    // ==========================================
    
    gaps 10
    background-color "transparent"
    
    // Отступы для панелей/доков (НАСТРОЙТЕ под Noctalia!)
    // Если док снизу — добавьте bottom: 40 (или высота вашего дока)
    struts {
        // top 30      // Если панель сверху (waybar?)
        // bottom 50   // Если Noctalia dock снизу
        // left 0
        // right 0
    }
    
    // ==========================================
    // 2. Column Behavior
    // ==========================================
    
    // Не центрировать при фокусе (классическое поведение тайлового WM)
    center-focused-column "always"
    
    // Ширина новых окон по умолчанию — половина экрана
    default-column-width { proportion 0.5; }
    
    // Предустановленные ширины (Mod+R для переключения)
    preset-column-widths {
        proportion 0.33333  // 1/3 — узкая
        proportion 0.5      // 1/2 — средняя (дефолт)
        proportion 0.66667  // 2/3 — широкая
    }
    
    // Предустановленные высоты окон в колонке (Mod+Shift+R)
    // Раскомментируйте если нужны фиксированные высоты:
    // preset-window-heights {
    //     proportion 0.33333
    //     proportion 0.5
    //     proportion 0.66667
    // }
    
    // ==========================================
    // 3. Focus Ring (Active Window Indicator)
    // ==========================================
    
    focus-ring {
        on
        width 3
        
        // Цвета под Noctalia/оранжевую тему
        active-color "#f9bb00"      // Яркий оранжевый
        inactive-color "#505050"    // Приглушённый серый
        
        // Альтернатива: градиент (раскомментируйте если хотите)
        // active-gradient from="#f9bb00" to="#ff8800" angle=45
    }
    
    // ==========================================
    // 4. Border (disabled — используем focus-ring)
    // ==========================================
    
    border {
        off
        // Если включить:
        // width 2
        // active-color "#707070"
        // inactive-color "#404040"
        // urgent-color "#cc4444"
    }
    
    // ==========================================
    // 5. Shadows
    // ==========================================
    
    shadow {
        softness 30        // Размытие тени
        spread 5           // Размер тени
        offset x=0 y=5     // Смещение вниз
        color "#0000007f"  // Полупрозрачный чёрный (was "#0007")
    }
    
    // ==========================================
    // 6. Tabbed Column Settings (Mod+W)
    // ==========================================
    
    // Настройки для табов (когда окна в колонке показываются как вкладки)
    tab-indicator {
        // Положение: top, bottom, left, right
        position "top"
        
        // Цвет активного таба
        active-color "#f9bb00"
        inactive-color "#404040"
        
        // Скругление углов табов
        // corner-radius 4
    }
}