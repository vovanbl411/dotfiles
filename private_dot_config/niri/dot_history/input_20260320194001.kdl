// ============================================
// Input Configuration
// ============================================

input {
    // ==========================================
    // Focus Behavior
    // ==========================================
    
    // max-scroll-amount="0%" предотвращает смену фокуса при скролле
    focus-follows-mouse max-scroll-amount="0%"
    
    // ==========================================
    // Keyboard
    // ==========================================
    
    keyboard {
        xkb {
            layout "us,ru"
            options "grp:win_space_toggle,compose:ralt"
            // compose:ralt позволяет вводить спецсимволы через Right Alt
        }
        
        // Включить numlock при старте
        numlock
    }
    
    // ==========================================
    // Touchpad (Laptop)
    // ==========================================
    
    touchpad {
        // Основное
        tap                     // Включить tap-to-click
        dwt                     // Отключать тачпад во время печати
        // dwtp                  // Отключать тачпад во время печати + короткая пауза после
        
        // Скролл (раскомментировать если нужен natural scroll)
        // natural-scroll
        
        // Ускорение (раскомментировать при необходимости)
        // accel-speed 0.0
        // accel-profile "adaptive"
        
        // Отключать тачпад при подключённой USB-мыши
        disabled-on-external-mouse
        
        // Метод скролла (два пальца — по умолчанию)
        // scroll-method "two-finger"
    }
    
    // ==========================================
    // Mouse (External)
    // ==========================================
    
    mouse {
        // Отключаем ускорение для точности (особенно в играх)
        accel-profile "flat"
        
        // Если flat слишком медленный/быстрый, настроить DPI мыши
        // или использовать accel-speed:
        // accel-speed -0.5  // медленнее
        // accel-speed 0.5   // быстрее
        
        // natural-scroll для мыши (редко нужен)
        // natural-scroll
    }
    
    // ==========================================
    // Trackpoint (ThinkPad/类似设备)
    // ==========================================
    
    trackpoint {
        // Раскомментировать для ThinkPad:
        // accel-profile "flat"
        // middle-emulation    // Средняя кнопка как клик колёсиком
        
        // Прокрутка средней кнопкой:
        // scroll-method "on-button-down"
        // scroll-button 273   // Код средней кнопки
    }
    
    // ==========================================
    // Tablet (если используете графический планшет)
    // ==========================================
    
    // tablet {
    //     map-to-output "eDP-1"
    // }
    
    // ==========================================
    // Warp Mouse (опционально)
    // ==========================================
    
    // Перемещать курсор на новое окно при смене фокуса клавишами
    // warp-mouse-to-focus true
}