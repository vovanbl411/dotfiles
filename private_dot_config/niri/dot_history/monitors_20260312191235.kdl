// Monitor notebook right
output "eDP-1" {
    mode "1920x1080@60"
    scale 1
    position x=2560 y=0
}

// Main monitor
output "DP-1" {
    mode "2560x1440@99.946"
    scale 1
    position x=0 y=0
}

// Left vertical monitor
output "HDMI-A-1" {
    mode "1920x1080@60"
    scale 1
    transform "270"
    position x=-1080 y=0
}

 // Bottom monitor
output "DP-3" {
    mode "2560x1600@60"
    scale 1.25
    position x=0 y=1440
}
