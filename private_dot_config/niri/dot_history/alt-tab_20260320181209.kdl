// ============================================
// Alt-Tab Window Switcher Configuration
// ============================================

recent-windows {
    // Visual appearance
    highlight {
        corner-radius 12
        // Дополнительные опции:
        // active-color "#7fc8ff"      // Цвет активного окна
        // inactive-color "#505050"    // Цвет неактивных
    }
    
    // Window dimensions and layout
    // max-size [800 600]           // Максимальный размер окна switcher'а
    // column-width 300              // Ширина колонки превью
    
    // Keybindings (перенесите сюда из основного конфига!)
    binds {
        Alt+Tab         { next-window scope="output"; }
        Alt+Shift+Tab   { previous-window scope="output"; }
        Alt+grave       { next-window filter="app-id"; }
        Alt+Shift+grave { previous-window filter="app-id"; }
        
        // Дополнительные хоткеи:
        // Escape          { cancel; }
        // q               { cancel; }
        // Return          { confirm; }
        // space           { confirm; }
    }
}